  {
    "name": "onboarding rejects invalid email",
    "steps": [
      {
        "send": { "callback": "onboarding:start" },
        "expect": [
          { "method": "editMessageText", "payload": { "text": "Welcome to PocketOption Auto-Trader.\n\nI'll set up automated trading for your account. Tap the button below to begin." } }
        ]
      },
      {
        "send": { "callback": "onboarding:begin" },
        "expect": [
          { "method": "editMessageText", "payload": { "text": "Enter your PocketOption email address:" } }
        ]
      },
      {
        "send": { "text": "notanemail" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "That doesn't look like a valid email. Try again:" } }
        ]
      }
    ]
  },
